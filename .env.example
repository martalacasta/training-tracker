STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Optional Strava sync retry tuning (for 429/5xx responses)
STRAVA_RETRY_MAX=
STRAVA_RETRY_BASE_MS=

# Optional LLM integration
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional GitHub Models integration
# Defaults GITHUB_MODELS_API_URL to https://models.inference.ai.azure.com/chat/completions
GITHUB_MODELS_API_URL=
GITHUB_MODELS_MODEL=
GITHUB_MODELS_API_KEY=

# Optional per-activity advice scope controls
ACTIVITY_ADVICE_LOOKBACK_DAYS=
ACTIVITY_ADVICE_REGENERATE_STALE=
ACTIVITY_ADVICE_MAX_PER_RUN=
ACTIVITY_ADVICE_CONTEXT_LIMIT=

# Optional chat endpoint used by the frontend
VITE_CHAT_API_URL=
